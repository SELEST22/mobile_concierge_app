{
  "expo": {
    "name": "Selest Security - Mobile Concierge Service",
    "slug": "mobile-concierge",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "concierge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#012A4A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.selest.concierge"
    },
    "android": {
      "package": "com.selest.concierge",
      "adaptiveIcon": {
        "backgroundColor": "#012A4A"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
