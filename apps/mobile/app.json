{
  "expo": {
    "name": "Selest Security - Mobile Concierge Service",
    "slug": "mobile-concierge",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "concierge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A001C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.selest.concierge"
    },
    "android": {
      "package": "com.selest.concierge",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive_icon.png",
        "backgroundColor": "#0A001C"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Selest Security to use the camera to scan event QR codes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "48eae466-efcf-496e-8b75-071a458153d9"
      }
    },
    "owner": "selest-security"
  }
}
