# Firebase config for the mobile app.
#
# Use the SAME Firebase project as the web app so the two stay in sync.
# These mirror the web app's NEXT_PUBLIC_FIREBASE_* values (copy them across).
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the app bundle.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
