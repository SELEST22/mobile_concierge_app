# Copy to ".env" and adjust as needed.

# Port the API listens on.
PORT=4000

# Secret used to sign JWTs. CHANGE THIS in any real deployment.
JWT_SECRET=dev-only-change-me

# How long an auth token stays valid.
JWT_EXPIRES_IN=7d

# PostgreSQL connection string.
# Local dev (matches docker-compose.yml): start it with `docker compose up -d`.
DATABASE_URL=postgres://concierge:concierge@localhost:5432/concierge

# Set to "true" when your managed Postgres requires SSL (most cloud hosts do).
DATABASE_SSL=false

# Default lifetime of a broadcast message, in days.
BROADCAST_DEFAULT_DAYS=30
